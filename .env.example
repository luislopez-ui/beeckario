# --- OpenAI ---
OPENAI_API_KEY=
# Ajusta al modelo disponible en tu cuenta
OPENAI_MODEL=gpt-4o-mini

# --- Beeckario backend ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
AUTOSTART_BACKEND=true

# --- Clockify ---
CLOCKIFY_API_KEY=
CLOCKIFY_WORKSPACE_ID=
CLOCKIFY_BASE_URL=https://api.clockify.me/api/v1
CLOCKIFY_TIMEOUT_S=30

# Timezone IANA (variabilizable)
CLOCKIFY_TIMEZONE=America/Mexico_City

# --- Modify/Search behavior (auto lookup of time entry IDs) ---
# When the user does NOT specify a date/time range (e.g. "modifica el registro del MIT.002"),
# Beeckario will search this many days backwards to find the entry ID.
CLOCKIFY_LOOKBACK_DAYS=7

# If multiple entries match and the user asked for a SINGLE record ("el registro ..."),
# Beeckario will auto-pick the most recent one to avoid asking for IDs.
# Set to 0 to disable (safer, but may require you to specify a time range).
CLOCKIFY_AUTOPICK_MOST_RECENT=1

# Tag por defecto (Arquitectura). Debe ser un ID de tag (24 hex)
CLOCKIFY_DEFAULT_TAG_ID=61f0377393930f642ee65f80

# Plantilla de descripción final. Placeholders:
#   {cliente}/{client}, {proyecto}/{project}, {actividad}/{activity}
CLOCKIFY_DESCRIPTION_TEMPLATE={cliente} | {proyecto} | {actividad}

# Max de registros a modificar/eliminar en bloque (seguridad)
CLOCKIFY_BULK_MAX=25

